# Required: backend API base URL
VITE_API_BASE_URL=http://localhost:8000/api

# Optional: frontend Google OAuth client id.
# Precedence: frontend env first, backend /api/auth/config fallback second.
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Optional: enable API interceptor debug logs in development.
VITE_DEBUG_API=false
