APP_ENV=development
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.1
OLLAMA_NUM_PREDICT=2048
OLLAMA_NUM_CTX=4096
OLLAMA_REQUEST_TIMEOUT_SECONDS=600
OLLAMA_KEEP_ALIVE=10m
OLLAMA_RETRY_ON_INVALID_RESPONSE=true
OLLAMA_RETRY_NUM_PREDICT=4096
OLLAMA_ENABLE_CACHE=true
OLLAMA_CACHE_TTL_SECONDS=600
OLLAMA_CACHE_MAX_ENTRIES=128
OLLAMA_VISION_MODEL=

# Database (PostgreSQL for production, SQLite for quick local dev)
DATABASE_URL=postgresql+psycopg2://tara:tara@localhost:5432/tara
# DATABASE_URL=sqlite:///./tara.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
# Optional: in development, defaults to false if unset. In production, defaults to true.
DB_STARTUP_STRICT=false

# Redis (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Notifications (optional — disabled by default)
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:5173

# Diagram extraction
DIAGRAM_MAX_UPLOAD_MB=10
DIAGRAM_PDF_MAX_PAGES=3
DIAGRAM_EXTRACT_TTL_SECONDS=1800
